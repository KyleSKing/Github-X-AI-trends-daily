# ============================================================
# X/Twitter 认证（twitter-cli）
# ============================================================
# 获取方式：
#   1. 浏览器登录 https://x.com
#   2. F12 → Application → Cookies → x.com
#   3. 复制 auth_token 和 ct0 的值
#
# 存储位置：
#   ~/.hermes/profiles/coder/home/.bashrc
#   export TWITTER_AUTH_TOKEN="xxx"
#   export TWITTER_CT0="xxx"
#
# 验证：
#   twitter whoami
# ============================================================

TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_value_here

# ============================================================
# GitHub 认证（gh CLI）
# ============================================================
# 存储位置：~/.config/gh/hosts.yml
# 验证：gh auth status
#
# ⚠️ 不要设置 GITHUB_TOKEN 环境变量，会覆盖 gh CLI 本地认证
# ============================================================
